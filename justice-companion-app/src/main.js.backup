  } catch (error) {
    securityManager.auditLog("AI_INTERACTION", "TEMPLATE_GENERATION_FAILED", {
      error: error.message,
      userId: event.sender.session?.userId
    });
    return { success: false, error: error.message };
  }
});

// AI Clear Session
ipcMain.handle("ai-clear-session", async (event, sessionId) => {
  try {
    const userId = event.sender.session?.userId || "anonymous";

    if (!securityManager.checkRateLimit("ai_clear", userId)) {
      throw new Error("Rate limit exceeded");
    }

    await apiIntegration.clearSession(sessionId);

    securityManager.auditLog("AI_INTERACTION", "SESSION_CLEARED", {
      userId: userId,
      sessionId: sessionId
    });

    return { success: true };
  } catch (error) {
    return { success: false, error: error.message };
  }
});

// Clean exit with proper cleanup
app.on('before-quit', async () => {
  try {
    if (apiIntegration) {
      apiIntegration.destroy();
      console.log('🤖 AI Integration: Cleaned up');
    }

    if (secureDatabase) {
      await secureDatabase.close();
    }

    if (securityManager) {
      securityManager.auditLog('APPLICATION', 'APPLICATION_SHUTDOWN', {
        shutdownTime: new Date().toISOString()
      });
    }

    console.log('🔒 Justice Companion: Secure shutdown complete');
  } catch (error) {
    console.error('Error during shutdown:', error);
  }
});

