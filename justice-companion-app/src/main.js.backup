// AI Chat - the brain of Justice Companion
ipcMain.handle("ai-chat", async (event, { query, sessionId, options }) => {
  try {
    const userId = event.sender.session?.userId || "anonymous";

    // Rate limiting for AI requests
    if (!securityManager.checkRateLimit("ai_chat", userId)) {
      throw new Error("AI rate limit exceeded");
    }

    // Validate and sanitize input
    const validation = securityManager.validateAndSanitizeInput(query, "ai_query");
    if (!validation.isValid) {
      throw new Error("Invalid query: " + validation.errors.join(", "));
    }

    // Process with API Integration
    const result = await apiIntegration.processQuery(validation.sanitized, sessionId, options);

    // Audit the AI interaction
    securityManager.auditLog("AI_INTERACTION", "CHAT_REQUEST", {
      userId: userId,
      sessionId: sessionId,
      queryLength: query.length,
      success: result.success
    });

    return result;
  } catch (error) {
    securityManager.auditLog("AI_INTERACTION", "CHAT_REQUEST_FAILED", {
      error: error.message,
      userId: event.sender.session?.userId
    });
    return { success: false, error: error.message };
  }
});

