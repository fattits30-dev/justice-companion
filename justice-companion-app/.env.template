# Justice Companion Configuration Template
# Copy this file to .env and configure your values

# ===============================
# CORE APPLICATION SETTINGS
# ===============================

# Environment (development, staging, production)
NODE_ENV=development

# Application Name and Version
APP_NAME=Justice Companion
APP_VERSION=1.0.0

# ===============================
# AI SERVICE CONFIGURATION
# ===============================

# Ollama Service Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=30000
OLLAMA_MAX_RETRIES=3

# AI Service Configuration
AI_MAX_CONTEXT_LENGTH=4096
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024

# ===============================
# DATABASE CONFIGURATION
# ===============================

# Database Path (SQLite)
DB_PATH=./data/justice-companion.db
DB_ENCRYPTION_KEY=your-encryption-key-here

# Database Connection Settings
DB_CONNECTION_TIMEOUT=5000
DB_MAX_CONNECTIONS=10

# ===============================
# DEVELOPMENT SERVER SETTINGS
# ===============================

# Vite Dev Server
VITE_DEV_PORT=5174
VITE_DEV_HOST=localhost

# Electron Window Settings
ELECTRON_WINDOW_WIDTH=1200
ELECTRON_WINDOW_HEIGHT=800

# ===============================
# SECURITY CONFIGURATION
# ===============================

# Session Management
SESSION_SECRET=your-session-secret-here
SESSION_TIMEOUT=3600000

# Encryption Settings
ENCRYPTION_ALGORITHM=AES-256-GCM
ENCRYPTION_KEY_ROTATION_DAYS=90

# ===============================
# LEGAL COMPLIANCE SETTINGS
# ===============================

# Data Retention Policies (in days)
CASE_DATA_RETENTION_DAYS=2555  # 7 years
CLIENT_DATA_RETENTION_DAYS=2555
AUDIT_TRAIL_RETENTION_DAYS=3650  # 10 years

# GDPR Compliance
GDPR_ENABLED=true
AUDIT_LOGGING_ENABLED=true

# ===============================
# LOGGING CONFIGURATION
# ===============================

# Log Levels: error, warn, info, debug
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/justice-companion.log
LOG_MAX_SIZE=50MB
LOG_MAX_FILES=10

# ===============================
# NETWORK CONFIGURATION
# ===============================

# Allowed Origins (CORS)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000

# API Rate Limiting
API_RATE_LIMIT_WINDOW=900000  # 15 minutes
API_RATE_LIMIT_MAX_REQUESTS=100

# ===============================
# FEATURE FLAGS
# ===============================

# Enable/Disable Features
FEATURE_DOCUMENT_GENERATION=true
FEATURE_CASE_MANAGEMENT=true
FEATURE_AI_ANALYSIS=true
FEATURE_CLIENT_PORTAL=false

# ===============================
# CLOUD DEPLOYMENT SETTINGS
# ===============================

# Service Discovery (for cloud deployment)
SERVICE_DISCOVERY_URL=
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENDPOINT=/metrics

# Container Settings
CONTAINER_PORT=3000
CONTAINER_HOST=0.0.0.0

# ===============================
# LEGAL CATEGORY CONFIGURATION
# ===============================

# Supported Legal Categories
LEGAL_CATEGORIES=housing,employment,consumer,council,insurance,debt,benefits

# Default Legal Jurisdiction
DEFAULT_JURISDICTION=UK
DEFAULT_LEGAL_SYSTEM=English

# ===============================
# BACKUP AND RECOVERY
# ===============================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups