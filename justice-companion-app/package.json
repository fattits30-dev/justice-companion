{
  "name": "justice-companion",
  "version": "0.1.0",
  "description": "Free legal aid for those who can't afford justice - built from pain, powered by truth",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_NO_WARNINGS=1 vite",
    "dev:web": "cross-env NODE_NO_WARNINGS=1 vite --host",
    "build": "cross-env NODE_NO_WARNINGS=1 vite build",
    "build:web": "cross-env NODE_NO_WARNINGS=1 vite build --mode web",
    "preview": "cross-env NODE_NO_WARNINGS=1 vite preview",
    "preview:web": "cross-env NODE_NO_WARNINGS=1 vite preview --host",
    "serve": "npm run build && npm run preview",
    "serve:web": "npm run build:web && npm run preview:web",
    "watch": "node file-watcher.js",
    "dev:watched": "npm run watch & npm run dev",
    "dev:full": "npm run watch & npm run dev:web",
    "dist": "npm run build && electron-builder",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "deploy:web": "npm run build:web && echo 'Web build ready for deployment'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check:watch": "tsc --noEmit --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "test:web": "npm run serve:web & sleep 5 && npm run test:e2e && killall node",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "legal",
    "justice",
    "uk-law",
    "free",
    "open-source",
    "civil-rights"
  ],
  "author": "The People",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-jest": "^30.1.2",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.3.0",
    "dompurify": "^3.2.7",
    "dotenv": "^17.2.2",
    "electron-store": "^8.2.0",
    "express-rate-limit": "^7.1.5",
    "jsdom": "^27.0.0",
    "ollama": "^0.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semver": "^7.7.2",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.17.0"
  },
  "build": {
    "appId": "com.justice.companion",
    "productName": "Justice Companion",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
