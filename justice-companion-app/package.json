{
  "name": "justice-companion",
  "version": "0.1.0",
  "description": "Free legal aid for those who can't afford justice - built from pain, powered by truth",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "legal",
    "justice",
    "uk-law",
    "free",
    "open-source",
    "civil-rights"
  ],
  "author": "The People",
  "license": "MIT",
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite3": "^5.1.7",
    "ollama": "^0.5.8",
    "axios": "^1.7.7",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.justice.companion",
    "productName": "Justice Companion",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
